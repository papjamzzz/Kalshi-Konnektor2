KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
paste your full private key PEM contents here
-----END PRIVATE KEY-----"

# Optional if you use Vegas odds via The Odds API
ODDS_API_KEY=your-odds-api-key-here
ODDS_CACHE_FILE=odds_cache.json
ODDS_CACHE_MAX_AGE_MINUTES=720
ODDS_CACHE_WRITE_ON_SUCCESS=true
ENABLE_ESPN_ODDS_FALLBACK=true
ENABLE_QUOTE_WINDOW_MONITOR=true
QUOTE_WINDOW_MONITOR_FILE=quote_window_monitor.json

# Polling interval in seconds
POLL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=10

# Set these to true to auto-scan league-specific pregame markets instead of using WATCHLIST
AUTO_NBA_PREGAME=false
AUTO_NHL_PREGAME=false
AUTO_MLB_PREGAME=false
AUTO_LOOKAHEAD_HOURS=24
MAX_AUTO_CANDIDATES=5
AUTO_CONTRACTS=2
AUTO_TAKE_PROFIT_CENTS=8
AUTO_STOP_LOSS_CENTS=10
AUTO_MAX_PRICE_CENTS=70
AUTO_MIN_TIME_TO_CLOSE_MINUTES=20
MIN_AUTO_MATCH_CONFIDENCE=0.6
ENABLE_NBA_INJURY_WATCHER=true
ENABLE_NHL_INJURY_WATCHER=true
INJURY_WATCHER_INTERVAL_SECONDS=900

# Set to false when ready for real orders
DRY_RUN=true

# Edge model and trading guards
MIN_VOLUME=500
MIN_EDGE_CENTS=3
MAX_SOURCE_DISAGREEMENT_CENTS=20
MAX_ACTIVE_POSITIONS=3
MAX_CONTRACTS_PER_POSITION=10
MAX_POSITION_COST_CENTS=2000
MAX_TOTAL_EXPOSURE_CENTS=5000
MAX_DAILY_TRADES=10
MAX_DAILY_REALIZED_LOSS_CENTS=1500
EXIT_ON_FAIR_VALUE=true
FAIR_EXIT_BUFFER_CENTS=1
COOLDOWN_MINUTES=60
DISABLE_NEW_ENTRIES=false

# Source weights used unless overridden per watchlist entry
DEFAULT_POLYMARKET_WEIGHT=0.55
DEFAULT_VEGAS_WEIGHT=0.35
DEFAULT_MANUAL_WEIGHT=0.10

# Optional state file path
STATE_FILE=bot_state.json
INJURY_WATCHER_STATE_FILE=injury_watcher_state.json
